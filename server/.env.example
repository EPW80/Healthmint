# Healthmint server environment variables.
# Copy to .env and fill in values. Never commit the populated .env file.

# ── Required ─────────────────────────────────────────────────────────────────

# 32-byte (64 hex char) Key Encryption Key for wrapping per-dataset symmetric
# keys before storage in MongoDB (see server/utils/keyWrap.js).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEALTHMINT_KEK=

# JWT signing secret. The server REFUSES TO BOOT if this is unset.
JWT_SECRET=

# MongoDB Atlas connection string.
MONGODB_URI=

# ── Server ────────────────────────────────────────────────────────────────────

# Node environment: development | test | production
NODE_ENV=development

# Port the server listens on (defaults to 5000).
PORT=5000

# Comma-separated list of allowed CORS origins. Defaults to REACT_APP_API_URL.
ALLOWED_ORIGINS=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Frontend URL (used for CORS and redirect generation).
FRONTEND_URL=http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────────────────

# JWT / token expiry durations (e.g. "1h", "7d").
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d
TOKEN_EXPIRY=1h

# Set to "true" to use HTTP-only cookies for session auth instead of
# Authorization: Bearer headers.
USE_COOKIE_AUTH=false

# Max failed login attempts before lockout.
MAX_LOGIN_ATTEMPTS=5

# Require MFA for all users.
REQUIRE_MFA=false
MFA_ISSUER=Healthmint

# ── Encryption ────────────────────────────────────────────────────────────────

# At-rest field encryption key used by hipaaConfig.js for PHI fields on the
# User and HealthData models. Distinct from HEALTHMINT_KEK above:
# HEALTHMINT_KEK wraps per-dataset payload keys; ENCRYPTION_KEY encrypts
# per-field PHI inside Mongo documents. Both should be 32-byte hex strings.
ENCRYPTION_KEY=

# ── Web3 / Blockchain ─────────────────────────────────────────────────────────

# Full RPC endpoint URLs, e.g.:
#   https://sepolia.infura.io/v3/<YOUR_KEY>
#   https://rpc.sepolia.org  (free public fallback — no key required)
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
DEFAULT_RPC_URL=https://rpc.sepolia.org

# Ethereum network ID (Sepolia = 11155111).
NETWORK_ID=11155111

# Blockchain network name (used in config/networkConfig.js).
BLOCKCHAIN_NETWORK=sepolia

# Private key for the server wallet used to sign transactions (no 0x prefix).
# Leave blank if transaction signing is not needed.
PRIVATE_KEY=

# Deployed contract addresses (populated automatically by deploy-direct.js).
CONTRACT_HEALTH_DATA_MARKETPLACE=
CONTRACT_PATIENT_CONSENT=
CONTRACT_HEALTH_DATA_REGISTRY=
CONTRACT_ADDRESS=

# Token / registry contract addresses (if using separate token or registry).
TOKEN_ADDRESS=
REGISTRY_ADDRESS=

# Etherscan API key for contract verification.
ETHERSCAN_API_KEY=

# Gas settings.
GAS_LIMIT=8000000
GAS_PRICE_STRATEGY=medium
MAX_GAS_PRICE=100
TRANSACTION_CONFIRMATIONS=2

# Infura credentials (alternative to a raw RPC URL).
INFURA_API_KEY=
INFURA_KEY=

# ── Storage / IPFS ────────────────────────────────────────────────────────────

# Storage backend: "pinata" | "web3storage" | "local"
STORAGE_TYPE=pinata

# Pinata IPFS pinning (preferred — see server/services/pinataService.js).
# Create a JWT at https://app.pinata.cloud/keys and paste it here.
PINATA_JWT=
# Optional: your dedicated Pinata gateway subdomain (leave blank to use the
# public gateway.pinata.cloud — dedicated gateways are faster and rate-limit-free).
PINATA_GATEWAY=https://gateway.pinata.cloud

# IPFS_PROVIDER controls which backend secureStorageService uses.
# "pinata" is the only supported pinning provider; "local" stores files on disk
# (used as a fallback when PINATA_JWT is unset).
IPFS_PROVIDER=pinata

# Public IPFS HTTP gateway used to retrieve content. Defaults to the Pinata
# gateway; any standards-compliant gateway works (e.g. https://ipfs.io/ipfs/).
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: error | warn | info | http | debug
LOG_LEVEL=debug
LOG_DIR=./logs
CONSOLE_LOG_LEVEL=info
MAX_LOG_SIZE=5242880
MAX_LOG_FILES=5

# ── HIPAA / Compliance ────────────────────────────────────────────────────────

HIPAA_AUDIT_ENABLED=true
HIPAA_SESSION_TIMEOUT=3600
HIPAA_PASSWORD_MIN_LENGTH=12

# ── Features ─────────────────────────────────────────────────────────────────

FEATURE_BLOCKCHAIN_VERIFICATION=true
FEATURE_CONSENT_MANAGEMENT=true
FEATURE_DATA_EXPORT=true
FEATURE_EMERGENCY_ACCESS=false

# ── Notifications ─────────────────────────────────────────────────────────────

NOTIFICATIONS_EMAIL=false
NOTIFICATIONS_SMS=false
NOTIFICATIONS_IN_APP=true

# ── Request tuning ────────────────────────────────────────────────────────────

REQUEST_TIMEOUT=30000
RETRY_ATTEMPTS=3
