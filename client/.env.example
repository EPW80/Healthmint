# Healthmint client environment variables (Create React App).
# Copy to .env and fill in values. Never commit the populated .env file.
# All variables MUST be prefixed with REACT_APP_ to be visible in the browser bundle.

# RPC endpoint URLs used when MetaMask needs to add a network to its chain list.
# If unset, the app falls back to the public endpoint (https://rpc.sepolia.org).
# Example using Infura: https://sepolia.infura.io/v3/<YOUR_KEY>
REACT_APP_SEPOLIA_RPC_URL=
REACT_APP_MAINNET_RPC_URL=

# Backend API base URL (defaults to http://localhost:5000 in development).
REACT_APP_API_URL=http://localhost:5000
