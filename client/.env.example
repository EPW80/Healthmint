# Healthmint client environment variables (Create React App).
# Copy to .env and fill in values. Never commit the populated .env file.
# All variables MUST be prefixed with REACT_APP_ to be visible in the browser bundle.

# ── API ───────────────────────────────────────────────────────────────────────

# Backend API base URL (defaults to http://localhost:5000 in development).
REACT_APP_API_URL=http://localhost:5000

# API request timeout in ms.
REACT_APP_API_TIMEOUT=30000

# Number of retry attempts for failed requests.
REACT_APP_RETRY_ATTEMPTS=3

# ── Blockchain / Network ──────────────────────────────────────────────────────

# Deployed marketplace contract address (from deploy-direct.js output).
REACT_APP_CONTRACT_ADDRESS=

# Ethereum chain ID (Sepolia = 11155111).
REACT_APP_CHAIN_ID=11155111

# Ethereum network ID.
REACT_APP_NETWORK_ID=11155111

# RPC endpoint URLs used when MetaMask needs to add a network.
# Defaults to public endpoint (https://rpc.sepolia.org) if unset.
REACT_APP_SEPOLIA_RPC_URL=
REACT_APP_MAINNET_RPC_URL=
REACT_APP_LOCAL_RPC_URL=http://localhost:8545

# Infura project ID (optional — only needed if using Infura instead of a public RPC).
REACT_APP_INFURA_PROJECT_ID=
REACT_APP_INFURA_PROJECT_SECRET=

# ── Storage / IPFS ────────────────────────────────────────────────────────────

# Web3.Storage token (if pinning directly from the client — not recommended for prod).
REACT_APP_WEB3_STORAGE_TOKEN=

# IPFS gateway for retrieving files.
REACT_APP_IPFS_GATEWAY=https://w3s.link
REACT_APP_IPFS_HOST=ipfs.infura.io
REACT_APP_IPFS_PORT=5001
REACT_APP_IPFS_PROTOCOL=https

# ── Etherscan ─────────────────────────────────────────────────────────────────

REACT_APP_ETHERSCAN_API_KEY=
REACT_APP_ETHERSCAN_URL=https://sepolia.etherscan.io

# ── App ───────────────────────────────────────────────────────────────────────

# App environment label (development | staging | production).
REACT_APP_ENV=development

# App version (populated by CI or npm version).
REACT_APP_VERSION=1.0.0

# Frontend URL (used for CORS-matched redirects).
REACT_APP_FRONTEND_URL=http://localhost:3000

# Set to "true" to force mock data regardless of API availability.
# Should always be "false" in staging/production.
REACT_APP_USE_MOCK_DATA=false

# Set to "true" to log payment debug output to console in development.
REACT_APP_PAYMENT_DEBUG=false

# Error monitoring DSN (e.g. Sentry — leave blank to disable).
REACT_APP_ERROR_MONITORING=
